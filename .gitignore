# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android local files / secrets
android/local.properties
**/key.properties
**/*.jks
**/*.keystore

# Firebase (treat as sensitive for public repos)
android/app/google-services.json
**/GoogleService-Info.plist

# Build outputs (not just root /build)
**/build/

# ==================== Secrets / Env ====================
# Never commit real environment files.
.env
.env.*
!.env.example
!.env.template
**/.env
**/.env.*
!**/.env.example
!**/.env.template

# ==================== Python ====================
__pycache__/
*.py[cod]
*.pyd
.venv/
venv/
backend/venv/

# Local backend artifacts
backend/logs/
backend/server.log
