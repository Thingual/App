# Thingual Backend Environment Configuration
# Copy this file to .env and fill in the values

# ==================== DATABASE ====================
# NeonDB PostgreSQL Connection String
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ==================== JWT SECURITY ====================
# Change this to a strong random string in production
SECRET_KEY=your-super-secret-key-change-this-in-production-12345

# JWT Algorithm (HS256 recommended)
ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== GOOGLE OAUTH ====================
# Get these from Google Cloud Console
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ==================== EMAIL CONFIGURATION ====================
# For password reset emails and OTP verification
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# ==================== TWILIO (Optional) ====================
# For SMS OTP delivery
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ==================== SERVER CONFIGURATION ====================
# Server host and port
API_HOST=0.0.0.0
API_PORT=8002

# Debug mode (set to False in production)
DEBUG=False

# ==================== FRONTEND ORIGINS ====================
# CORS allowed origins (comma-separated)
# FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001
